#!/bin/bash
# LC7 launcher for Linux — generated by CMake at build time.
# Bundles Qt5, ICU, xcb under lib/ and platforms/ inside the same directory.
DIR="$(cd "$(dirname "$0")" && pwd)"
export LD_LIBRARY_PATH="$DIR/lib:$DIR:$LD_LIBRARY_PATH"
export QT_PLUGIN_PATH="$DIR"
export QT_QPA_PLATFORM_PLUGIN_PATH="$DIR/platforms"
# Force software OpenGL so the app works on headless / GPU-less systems.
export LIBGL_ALWAYS_SOFTWARE=1
export QT_XCB_GL_INTEGRATION=none
export QT_OPENGL=software
exec "$DIR/lc7" "$@"
