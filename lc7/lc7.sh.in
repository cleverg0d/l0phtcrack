#!/bin/bash
# LC7 launcher for Linux — generated by CMake at build time.
# Bundles Qt5, ICU, xcb under lib/ and platforms/ inside the same directory.
DIR="$(cd "$(dirname "$0")" && pwd)"
export LD_LIBRARY_PATH="$DIR/lib:$DIR:$LD_LIBRARY_PATH"
export QT_PLUGIN_PATH="$DIR"
export QT_QPA_PLATFORM_PLUGIN_PATH="$DIR/platforms"
# Force software OpenGL — works on headless / GPU-less / VPS systems.
# swrast_dri.so is bundled in dri/ so no GPU driver needed.
export LIBGL_ALWAYS_SOFTWARE=1
export LIBGL_DRIVERS_PATH="$DIR/dri"
export MESA_LOADER_DRIVER_OVERRIDE=swrast
export QT_XCB_GL_INTEGRATION=none
export QT_OPENGL=software
# Prevent loading SYSTEM Qt theme/style/input plugins that are ABI-incompatible
# with our bundled Qt Core. Qt always searches /usr/lib/.../qt5/plugins/ regardless
# of qt.conf — these env vars stop it from loading those incompatible plugins.
export QT_QPA_PLATFORMTHEME=
export QT_STYLE_OVERRIDE=Fusion
export QT_IM_MODULE=none
# On headless servers fall back to offscreen.
# Also detect DISPLAY set but X11 not actually running (common on VPS/cloud).
# X11 uses a Unix socket at /tmp/.X11-unix/X<N>; if it doesn't exist, xcb aborts.
_lc7_need_offscreen=0
if [ -z "$DISPLAY" ] && [ -z "$WAYLAND_DISPLAY" ]; then
    _lc7_need_offscreen=1
elif [ -n "$DISPLAY" ]; then
    # Extract display number (e.g. ":0" → "0", ":1.0" → "1")
    _lc7_dispnum="${DISPLAY##*:}"
    _lc7_dispnum="${_lc7_dispnum%%.*}"
    _lc7_xsock="/tmp/.X11-unix/X${_lc7_dispnum}"
    if [ ! -S "$_lc7_xsock" ]; then
        # Unix socket missing — X server is not running despite DISPLAY being set.
        unset DISPLAY
        _lc7_need_offscreen=1
    fi
fi
if [ "$_lc7_need_offscreen" = "1" ] && [ -z "$QT_QPA_PLATFORM" ]; then
    export QT_QPA_PLATFORM=offscreen
fi
exec "$DIR/lc7" "$@"
